# Django Settings
DEBUG=True
SECRET_KEY=postventa-system-secret-key-change-in-production-2024

# SQL Server Express Configuration - Windows Authentication
DB_NAME=postventa_system
DB_USER=                    # Empty for Windows Authentication
DB_PASSWORD=                # Empty for Windows Authentication
DB_HOST=localhost
DB_PORT=62161               # Puerto dinámico de tu SQL Server Express
DB_INSTANCE=SQLEXPRESS

# Redis
REDIS_URL=redis://localhost:6379/0

# Shared Folder Path (Windows UNC path)
