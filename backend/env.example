# Django Settings
DEBUG=False
DJANGO_ENV=production
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECURE_VALUE
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,192.168.1.234
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://192.168.1.234:3000
DJANGO_CSRF_TRUSTED_ORIGINS=http://192.168.1.234
USE_SECURE_PROXY=True
USE_X_FORWARDED_HOST=True

# Database
# SQL Server connection string example
# Format: mssql+pyodbc://USER:PASSWORD@HOST\INSTANCE/DATABASE?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes
DATABASE_URL=mssql+pyodbc://username:password@localhost\\SQLEXPRESS/postventa_system?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Shared documents path (local to project directory when copied to remote desktop)
SHARED_DOCUMENTS_PATH=

# AI Providers (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Email Settings (optional)
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@postventa.local
